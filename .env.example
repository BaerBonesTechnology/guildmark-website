# GuildMark — Root environment template
# Copy to .env for local Docker Compose usage.
#   cp .env.example .env
# Never commit .env with real secrets.
# ---------------------------------------------------------------------------

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=guildmark
POSTGRES_USER=guildmark
POSTGRES_PASSWORD=change_me_in_local
POSTGRES_PORT=5432

# ── Dart API ──────────────────────────────────────────────────────────────────
API_PORT=8080
# DATABASE_URL is constructed from the Postgres vars above in docker-compose.
# Override here only if you need a custom connection string.
# DATABASE_URL=postgres://guildmark:change_me_in_local@postgres:5432/guildmark
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_long_random_string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# CORS_ORIGIN must allow both frontends when running side-by-side.
CORS_ORIGIN=http://localhost:3000
GM_DEBUG=false

# ── ML service (optional — only active with: docker compose --profile ml up) ──
ML_PORT=8001
ML_MODEL_DIR=/app/model_artifacts
# Leave empty to disable ML; API will return 503 from valuation endpoints.
ML_SERVICE_URL=http://ml:8001

# ── Frontend ports ────────────────────────────────────────────────────────────
GUILDMARK_PORT=3000
DEVDASH_PORT=3001

# ── Vite build args (baked into JS bundles — rebuild images after changing) ───
VITE_API_URL=http://localhost:8080
ADMIN_VITE_API_URL=http://localhost:8081
VITE_IS_LAUNCH=true
VITE_IS_DEBUG=false

# ── Square Web Payments ───────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox   # 'sandbox' or 'production'

# ── GuildMark Wallet — ACH payout account ────────────────────────────────────
GM_WALLET_ACH_ROUTING=
GM_WALLET_ACH_ACCOUNT=

# ── MDM integrations ──────────────────────────────────────────────────────────
JAMF_PRO_CLIENT_ID=
JAMF_PRO_CLIENT_SECRET=
INTUNE_TENANT_ID=
INTUNE_CLIENT_ID=
INTUNE_CLIENT_SECRET=

# ── Market data sources ───────────────────────────────────────────────────────
# eBay uses OAuth client-credentials — all three IDs are required.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
BACKMARKET_API_KEY=

# ── Email — Resend ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Leave empty to disable transactional emails (API still works, just skips sends).
RESEND_API_KEY=

# ── Escrow.com ────────────────────────────────────────────────────────────────
# Sign up at https://www.escrow.com/api and get sandbox credentials first.
# Leave empty to disable escrow (orders still work, just without escrowed funds).
ESCROW_API_KEY=
ESCROW_EMAIL=                        # your escrow.com account email
ESCROW_ENVIRONMENT=sandbox           # sandbox | production

# ── FedEx Track API ───────────────────────────────────────────────────────────
# Register at https://developer.fedex.com — create an app, get client ID/secret.
# FEDEX_WEBHOOK_SECRET: shared secret you set when registering the webhook in
#   the FedEx developer portal → your app → Notifications → Track Events.
# Leave empty to disable auto-delivery detection (buyers must confirm manually).
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_WEBHOOK_SECRET=
FEDEX_ENVIRONMENT=sandbox            # sandbox | production
